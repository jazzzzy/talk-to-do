rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /tasks/{taskId} {
      // Allow Read/Delete only if the user is authenticated and owns the document.
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      
      // Allow Create only if:
      // 1. User is authenticated.
      // 2. The userId matches their UID.
      // 3. Schema validation: title (string, 1-200), status (pending/completed).
      allow create: if request.auth != null 
                    && request.auth.uid == request.resource.data.userId
                    && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                    && request.resource.data.status in ['pending', 'completed']
                    && (!('dueDate' in request.resource.data) || request.resource.data.dueDate is string)
                    && request.resource.data.createdAt is int;

      // Allow Update only if:
      // 1. User owns the document.
      // 2. Ownership (userId) is not being changed.
      // 3. Schema validation for new data.
      allow update: if request.auth != null 
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.title is string && request.resource.data.title.size() > 0 && request.resource.data.title.size() <= 200
                    && request.resource.data.status in ['pending', 'completed']
                    && (!('dueDate' in request.resource.data) || request.resource.data.dueDate is string);
    }

    // Phase 5: Family calendar events (written by Cloud Functions, read by clients)
    match /calendarEvents/{eventId} {
      // Users can read their own synced events
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;

      // Users can update the mirroredToGcal flag on their own events
      allow update: if request.auth != null 
                    && request.auth.uid == resource.data.userId
                    && request.resource.data.userId == resource.data.userId
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['mirroredToGcal']);

      // Only Cloud Functions (Admin SDK) can create/delete — no client write rules
      allow create, delete: if false;
    }

    // Phase 5: User settings (calendar URL, preferences)
    match /userSettings/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.data.userId == userId;
    }
  }
}
